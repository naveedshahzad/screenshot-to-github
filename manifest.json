{
  "manifest_version": 3,
  "name": "Screenshot Uploader",
  "version": "1.0.0",
  "description": "Take full-page screenshots and upload them to catbox",
  
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Screenshot Uploader Settings",
    "default_icon": "images/icon.svg"
  },
  
  "options_page": "options.html",
  
  "devtools_page": "devtools_page.html",
  
  "icons": {
    "128": "images/icon.svg"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["html2canvas.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://catbox.moe https://cdnjs.cloudflare.com https://api.github.com"
  }
}
